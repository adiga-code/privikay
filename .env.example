# Telegram Bot
BOT_TOKEN=1234567890:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostgreSQL connection
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Examples:
#   Local:  postgresql+asyncpg://postgres:mypassword@localhost:5432/habits
#   Remote: postgresql+asyncpg://bot:mypassword@123.45.67.89:5432/habits
#   Dokploy/managed DB: postgresql+asyncpg://bot:mypassword@db-host:5432/habits
DB_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME

# YuKassa (format: shopId:MODE:secretKey)
YUKASSA_TOKEN=1234567:LIVE:live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated Telegram user IDs of admins
ADMIN_IDS=123456789,987654321

# URL of the running academy (shown to users after 7 days)
ACADEMY_URL=https://example.com/academy
